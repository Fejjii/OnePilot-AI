# ── App ──────────────────────────────────────────────────
APP_ENV=dev
APP_NAME=OnePilot AI

# ── OpenAI ───────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_SPEECH_MODEL=whisper-1

# ── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://onepilot:onepilot@localhost:5432/onepilot

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Qdrant ───────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── LangSmith (optional) ────────────────────────────────
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false

# ── Search (optional) ───────────────────────────────────
# Primary env file for Docker Compose (backend service env_file + substitution below).
SERPER_API_KEY=
SERPER_BASE_URL=https://google.serper.dev/search
SERPER_TIMEOUT_SECONDS=10
SERPER_MAX_RESULTS=5

# ── Gmail (optional — approval-gated) ───────────────────
# Setup: docs/gmail_oauth_setup.md
# Generate refresh token: cd backend && uv run python scripts/generate_gmail_refresh_token.py
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8765/
GMAIL_PROVIDER_MODE=auto
GMAIL_SEND_ENABLED=false

# ── Google Calendar (optional — approval-gated) ─────────
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_PROVIDER_MODE=auto
GOOGLE_CALENDAR_CREATE_ENABLED=true
GOOGLE_CALENDAR_DEFAULT_TIMEZONE=Europe/Berlin
GOOGLE_CALENDAR_LOOKAHEAD_DAYS=14
GOOGLE_CALENDAR_SLOT_DURATION_MINUTES=30
GOOGLE_CALENDAR_WORKDAY_START=09:00
GOOGLE_CALENDAR_WORKDAY_END=17:00

# ── CORS (optional — defaults to localhost:3000) ─────────
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Auth / JWT ───────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── Dev auth (bypasses JWT when no header is sent) ──────
DEV_AUTH_ENABLED=true
DEV_ORG_ID=org_demo_onepilot
DEV_USER_ID=usr_demo_admin
DEV_BYPASS_QUOTAS=false
