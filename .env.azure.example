# OnePilot AI — Azure demo environment template (placeholders only)
# Copy values into Azure Container App secrets / env — never commit real secrets.
#
# Frontend: NEXT_PUBLIC_API_URL is baked in at Docker image BUILD time.
# Rebuild the frontend image if the public backend URL changes.

# ── App ──────────────────────────────────────────────────
APP_ENV=dev
JWT_SECRET=replace-with-strong-secret
DEV_AUTH_ENABLED=true
DEV_BYPASS_QUOTAS=false

# ── CORS (comma-separated; must include your public frontend URL) ──
CORS_ALLOWED_ORIGINS=https://your-frontend-url,http://localhost:3000,http://127.0.0.1:3000

# ── Database ─────────────────────────────────────────────
# Azure Database for PostgreSQL Flexible Server often requires sslmode=require
DATABASE_URL=postgresql+psycopg://user:password@host:5432/dbname?sslmode=require

# ── Redis (optional — leave empty for in-memory fallback) ──
REDIS_URL=

# ── Qdrant ───────────────────────────────────────────────
QDRANT_URL=https://your-qdrant-url
QDRANT_API_KEY=

# ── OpenAI ───────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_SPEECH_MODEL=whisper-1

# ── Serper (optional web search) ─────────────────────────
SERPER_API_KEY=
SERPER_BASE_URL=https://google.serper.dev/search
SERPER_TIMEOUT_SECONDS=10
SERPER_MAX_RESULTS=5

# ── Gmail and Calendar (optional — server-side refresh token) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GMAIL_PROVIDER_MODE=auto
GMAIL_SEND_ENABLED=false
GOOGLE_CALENDAR_PROVIDER_MODE=auto
GOOGLE_CALENDAR_CREATE_ENABLED=true
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_AGGREGATE_SELECTED=true
GOOGLE_CALENDAR_DEFAULT_TIMEZONE=Europe/Berlin

# ── LangSmith (optional) ─────────────────────────────────
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=onepilot-ai

# ── Frontend image build (not a backend Container App env) ──
# Pass as Docker build-arg when building the frontend image:
#   docker build --build-arg NEXT_PUBLIC_API_URL=https://your-backend-url ...
NEXT_PUBLIC_API_URL=https://your-backend-url
