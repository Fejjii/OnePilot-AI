# ── App ──────────────────────────────────────────────────
APP_ENV=dev
APP_NAME=OnePilot AI

# ── OpenAI ───────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_SPEECH_MODEL=whisper-1

# ── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://onepilot:onepilot@localhost:5432/onepilot

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Qdrant ───────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── LangSmith (optional) ────────────────────────────────
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false

# ── Search (optional) ───────────────────────────────────
SERPER_API_KEY=

# ── Auth / JWT ───────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── Dev auth (bypasses JWT when no header is sent) ──────
DEV_AUTH_ENABLED=true
DEV_ORG_ID=org_demo_novaedge
DEV_USER_ID=usr_demo_admin
DEV_BYPASS_QUOTAS=false
